# ──────────────────────────────────────────────────────────────────
# Design Request Form — Environment Variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Add each variable to your Vercel project settings for production.
# ──────────────────────────────────────────────────────────────────

# The long ID in your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# Email address of the Google service account you created
# (looks like something@your-project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key from the service account JSON file.
# Paste the entire "private_key" value, keeping literal \n characters —
# do NOT expand them into real newlines in this file.
# Example: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
